<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>0e067a7d-a787-498d-aea5-e3ae4f8f6bf7</Id>
  <Version>1.0.3</Version>
  <ProviderName>JCB Ventures</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="AI Folder Advisor"/>
  <Description DefaultValue="AI-powered email folder suggestions for Outlook."/>
  <IconUrl DefaultValue="https://jcbventures.github.io/outlook-ai-sort/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://jcbventures.github.io/outlook-ai-sort/icon-128.png"/>
  <SupportUrl DefaultValue="https://jcbventures.github.io/outlook-ai-sort/"/>

  <AppDomains>
    <AppDomain>https://jcbventures.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://jcbventures.github.io/outlook-ai-sort/taskpane.html"/>
        <RequestedHeight>550</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="aiFolderAdvisorGroup">
                <Label resid="Group.Label"/>
                <Control xsi:type="Button" id="openAiFolderAdvisorButton">
                  <Label resid="Button.Label"/>
                  <Supertip>
                    <Title resid="Button.Label"/>
                    <Description resid="Button.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://jcbventures.github.io/outlook-ai-sort/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://jcbventures.github.io/outlook-ai-sort/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://jcbventures.github.io/outlook-ai-sort/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://jcbventures.github.io/outlook-ai-sort/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="Group.Label" DefaultValue="AI Folder Advisor"/>
        <bt:String id="Button.Label" DefaultValue="Suggest folder"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="Button.Tooltip" DefaultValue="Open AI Folder Advisor for this email."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>

</OfficeApp>
