<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="MailApp">

  <Id>0e067a7d-a787-498d-aea5-e3ae4f8f6bf7</Id>
  <Version>1.0.2</Version>
  <ProviderName>JCB Ventures</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="AI Folder Advisor"/>
  <Description DefaultValue="AI-powered email folder suggestions for Outlook."/>
  <IconUrl DefaultValue="https://jcbventures.github.io/outlook-ai-sort/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://jcbventures.github.io/outlook-ai-sort/icon-128.png"/>
  <SupportUrl DefaultValue="https://jcbventures.github.io/outlook-ai-sort/"/>

  <AppDomains>
    <AppDomain>https://jcbventures.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://jcbventures.github.io/outlook-ai-sort/taskpane.html"/>
        <RequestedHeight>550</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

</OfficeApp>
